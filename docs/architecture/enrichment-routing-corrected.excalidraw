      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "1. LinkedIn Current Experience (highest confidence)\n   URL: linkedin.com/company/kansas-city-chiefs\n   Domain: chiefs.com (from their LI company page)\n   Name: \"Kansas City Chiefs\"\n\n2. Work Email Domain\n   @chiefs.com \u2192 matches Chiefs child\n   @nfl.com \u2192 matches parent only (ambiguous)\n\n3. Provided Company Name (least reliable)\n   \"NFL\" \u2014 often generic, from import spreadsheet",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "el81",
      "originalText": "1. LinkedIn Current Experience (highest confidence)\n   URL: linkedin.com/company/kansas-city-chiefs\n   Domain: chiefs.com (from their LI company page)\n   Name: \"Kansas City Chiefs\"\n\n2. Work Email Domain\n   @chiefs.com \u2192 matches Chiefs child\n   @nfl.com \u2192 matches parent only (ambiguous)\n\n3. Provided Company Name (least reliable)\n   \"NFL\" \u2014 often generic, from import spreadsheet",
      "lineHeight": 1.25
    },
